node_modules
dist
dist-dev

# Screenshots / GIFs written by the headless scripting harness (tools/harness)
harness-shots/

# Claude Code local settings (per-developer preferences, not shared)
.claude/

# Test ROMs cloned locally for the `npm run test:roms` harness; not
# bundled — `npm run test:roms` auto-fetches the c-sp release zip on
# first run (set GLOWBOOT_NO_FETCH=1 to skip). The local accuracy
# report at `tests/roms/REPORT.md` is also developer-internal and
# stays out of the repo.
tests/roms/

# GBA test ROMs — `npm run test:gba-roms` auto-fetches the cadfan
# accuracy-test corpus (jsmolka + armwrestler + fuzzarm + mgba-suite +
# ags-aging) into this directory on first run.
tests/gba-roms/

# Vite env files — never commit any of them so secrets can't sneak in
# through the back door. The repo ships `.env.example` as the only
# documented contract; real values live in the deployment environment
# (Cloudflare Pages → Settings → Environment variables) and in each
# developer's local `.env.local`.
.env
.env.*
!.env.example

archive/
