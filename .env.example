# Cloudflare Worker URL for the link-cable relay. Browser clients
# upgrade to `wss://` automatically — set the `https://` form here.
#
# Production: set this in your Cloudflare Pages project under
#   Settings → Environment variables → Production
# (and optionally Preview, with the same value).
#
# Local dev: copy this file to `.env.local` (gitignored) and fill in
# the real URL only if you actually want to test cross-device pairing
# locally. Otherwise leave it unset — link-cable 2-player mode falls
# back to BroadcastChannel (same-machine pairing only) and dev work
# isn't blocked.
#
# Never commit a populated `.env*` file. `.gitignore` enforces this so
# unrelated secrets can't leak through the same channel later on.
VITE_LINK_RELAY_URL=https://relay.glowboot.workers.dev

# AI screenshot-upscaler model URL. The model is ~32 MB — too large for
# the Cloudflare Pages 25 MiB per-file limit — so it's hosted off-repo on
# Hugging Face. The value below is the default (also baked into the code);
# change it to swap in a different model or point at a local copy. A
# failed fetch only disables Enhance; the emulator runs fine.
VITE_UPSCALE_MODEL_URL=https://huggingface.co/glowboot/upscalers/resolve/main/pixelperfect-x4-fp16.onnx

# Translate-the-screen model hosting. Both default to our own Hugging Face
# mirror (populated by a maintainer-only mirror script) so translation
# doesn't depend on third-party repos staying up. A failed fetch only
# disables translation/OCR; the emulator runs fine.
#
# Offline translation: one repo per language, named <prefix><suffix>
# (e.g. glowboot/translator-en-de). transformers.js needs one model per
# repo. Override the prefix with VITE_MT_MODEL_PREFIX.
VITE_MT_MODEL_PREFIX=glowboot/translator-en-
# OCR (PP-OCRv5 detection / recognition / dict) — a single repo of files.
VITE_OCR_MODEL_BASE=https://huggingface.co/glowboot/recognizers/resolve/main
#
# To run against the public upstream before you've mirrored, set:
#   VITE_MT_MODEL_PREFIX=Xenova/opus-mt-en-   (the public per-language repos)
#   VITE_OCR_MODEL_BASE=                       (empty — ppu-paddle-ocr's bundled models)
