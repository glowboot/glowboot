{
  "name": "glowboot",
  "version": "1.3.0",
  "type": "module",
  "license": "MIT",
  "author": "the Glowboot authors",
  "description": "Play original Game Boy, Game Boy Color, and Game Boy Advance games in your browser. Built entirely with AI.",
  "homepage": "https://glowboot.pages.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glowboot/glowboot.git"
  },
  "private": true,
  "sideEffects": [
    "./src/main.ts",
    "./src/ui/**",
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p src/gb/tsconfig.json --noEmit && tsc -p src/gba/tsconfig.json --noEmit && tsc -p tests/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:roms": "tsx tests/run-roms.ts",
    "test:gba-roms": "tsx tests/run-gba-roms.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/pngjs": "^6.0.5",
    "adm-zip": "^0.5.17",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "onnxruntime-web": "^1.26.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
