{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "lib": ["ES2022", "DOM"],
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true
  },
  "include": ["src"],
  // globals.d.ts files are the engines' ambient-globals shims for the
  // DOM-less tsconfigs; the root config already has DOM so picking
  // them up here would collide with lib.dom.d.ts.
  "exclude": ["src/gb/globals.d.ts", "src/gba/globals.d.ts"]
}
